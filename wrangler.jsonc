{
  "main": "dist/server/entry.mjs",
  "name": "web-basic",
  "compatibility_date": "2026-02-28",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/client"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "363a85590e0f445c8ad926ce965eceb9",
      "preview_id": "363a85590e0f445c8ad926ce965eceb9"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.js",
        "**/*.mjs"
      ]
    }
  ],
  "no_bundle": true,
  "env": {
    "preview": {
      "name": "web-basic-preview",
      "workers_dev": true,
      "preview_urls": true,
      "kv_namespaces": [
        {
          "binding": "SESSION",
          "id": "363a85590e0f445c8ad926ce965eceb9",
          "preview_id": "363a85590e0f445c8ad926ce965eceb9"
        }
      ]
    }
  },
  "observability": {
    "enabled": true
  },
  "$schema": "node_modules/wrangler/config-schema.json"
}
