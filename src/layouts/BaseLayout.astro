---
import SEO from '../components/SEO.astro';
import '../styles/tokens.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  siteName?: string;
  lang?: string;
  type?: 'website' | 'article';
  noIndex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  siteName,
  lang = 'en',
  type = 'website',
  noIndex = false,
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      siteName={siteName}
      type={type}
      noIndex={noIndex}
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
