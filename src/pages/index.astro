---
import client from '../../tina/__generated__/client';
import siteContentJson from '../../content/tina/site-content.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import TinaInlineBridge from '../components/react/TinaInlineBridge.tsx';
import { addMetadata, hashFromQuery, tinaField } from 'tinacms/dist/react';
import '../styles/index.css';

const isLocalStaticBuild = import.meta.env.PROD && process.env.TINA_PUBLIC_IS_LOCAL === 'true';
const tinaPayload = isLocalStaticBuild ? null : await client.queries.siteContent({ relativePath: 'site-content.json' });
const queryIdentity = tinaPayload ? JSON.stringify({ query: tinaPayload.query, variables: tinaPayload.variables }) : '';
const siteContentResponse = tinaPayload
  ? addMetadata(hashFromQuery(queryIdentity), structuredClone(tinaPayload.data), [])
  : ({ siteContent: structuredClone(siteContentJson) } as { siteContent: Record<string, unknown> });
const siteContent = (siteContentResponse as { siteContent: Record<string, unknown> }).siteContent as any;

const {
  seoTitle,
  seoDescription,
  canonicalOrigin,
  ogImage,
  businessName,
  homepageUrl,
  header,
  hero,
  biomarkerPanel,
  featurePanel,
  trustSection,
  commandCenterSection,
  ourProcessSection,
  choosePathSection,
  faqSection,
  missionSection,
  newsletterSection,
  footerSection,
} = siteContent;

const tinaBridgeProps = tinaPayload
  ? {
      query: tinaPayload.query,
      variables: tinaPayload.variables as Record<string, unknown>,
      data: tinaPayload.data as unknown as Record<string, unknown>,
    }
  : null;

const serviceCards = [
  ...featurePanel.cards,
  {
    alt: featurePanel.prescriptionCard.alt,
    titleLine1: featurePanel.prescriptionCard.titleLine1,
    titleLine2: featurePanel.prescriptionCard.titleLine2,
    href: featurePanel.prescriptionCard.href,
  },
];

const imageMap = {
  hero: '/images/hero.svg',
  card1: '/images/service-card-1.svg',
  card2: '/images/service-card-2.svg',
  card3: '/images/service-card-3.svg',
  command: '/images/command-center.svg',
  process: '/images/process.svg',
  faq: '/images/faq-card.svg',
  mission: '/images/mission.svg',
  gallery1: '/images/gallery-1.svg',
  gallery2: '/images/gallery-2.svg',
  newsletter: '/images/newsletter-bg.svg',
  footer: '/images/footer-card.svg',
};

const avatarMap = ['/images/avatar-1.svg', '/images/avatar-2.svg', '/images/avatar-3.svg', '/images/avatar-4.svg'];

const externalSocials = [
  { label: 'Website', href: homepageUrl ?? '/' },
  { label: 'WhatsApp', href: header?.whatsAppHref ?? '/' },
];

const biomarkerItems = (biomarkerPanel.items ?? []).filter((item) => Boolean(item));
const biomarkerRows = [biomarkerItems.slice(0, 3), biomarkerItems.slice(3, 7), biomarkerItems.slice(7, 10)];
const biomarkerRowStarts = [0, 3, 7];
const biomarkerMobileSpeeds = [34, 41, 37];
const biomarkerMobileOffsets = [102.083, 728.5, 652.667];

const resolveBiomarkerImage = (imagePath: string | undefined) => {
  if (!imagePath) return '/images/hero.svg';
  return imagePath;
};
---

<BaseLayout title={seoTitle} description={seoDescription} canonical={canonicalOrigin} ogImage={ogImage} siteName={businessName}>
    {
      tinaBridgeProps && (
        <>
          {/* @ts-expect-error custom Astro client directive */}
          <TinaInlineBridge {...tinaBridgeProps} client:tina />
        </>
      )
    }

    <header class="ep-header" data-ep-header data-tina-field={tinaField(siteContent, 'header')}>
      <div class="container ep-header__container">
        <div class="ep-header__shell">
          <div class="ep-header__ring ep-header__ring--outer" aria-hidden="true"></div>
          <div class="ep-header__ring ep-header__ring--inner" aria-hidden="true"></div>

          <div class="ep-header__inner">
            <a href="#top" class="ep-header__logo-link" aria-label={`${businessName} home`}>
              <img src="/images/logo-blue.svg" alt="Logo" width="85" height="22" class="ep-header__logo" />
            </a>

            <nav class="ep-header__nav" aria-label="Main">
              <ul class="ep-header__nav-list">
                {header.navItems.map((item, index) => (
                  <li>
                    <a href={item.href} class="ep-header__nav-link" data-tina-field={tinaField(header, 'navItems', index)}>
                      <span>{item.label}</span>
                    </a>
                  </li>
                ))}
              </ul>

              <div class="ep-header__cta-group">
                <div class="ep-btn-shell ep-btn-shell--soft">
                  <div class="ep-soft-liquid">
                    <div class="ep-soft-liquid__frame">
                      <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                      <a
                        href={header.whatsAppHref}
                        class="ep-btn ep-btn--soft ep-soft-liquid__link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span>{header.primaryCtaLabel}</span>
                      </a>
                    </div>
                  </div>
                </div>
                <div class="ep-btn-shell">
                  <div class="ep-dark-liquid">
                    <div class="ep-dark-liquid__frame">
                      <div class="ep-dark-liquid__overlay" aria-hidden="true"></div>
                      <a href={header.secondaryCtaHref} class="ep-btn ep-btn--dark ep-dark-liquid__link">
                        <span class="ep-btn-label">{header.secondaryCtaLabel}</span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </nav>

            <button
              class="ep-header__menu-btn"
              type="button"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobile-nav"
              data-ep-menu-btn
            >
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </button>
          </div>
        </div>

        <div class="ep-mobile-panel" id="mobile-nav" role="dialog" aria-modal="true" aria-label="Mobile navigation" hidden>
          <div class="ep-mobile-panel__head">
            <a href="#top" class="ep-mobile-panel__logo-link" aria-label={`${businessName} home`}>
              <img src="/images/logo-blue.svg" alt="Logo" width="85" height="22" class="ep-mobile-panel__logo" />
            </a>

            <button
              class="ep-mobile-panel__close-btn"
              type="button"
              aria-label="Close menu"
              aria-expanded="true"
              aria-controls="mobile-nav"
              data-ep-menu-close
            >
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </button>
          </div>

          <div class="ep-mobile-panel__body">
            <div class="ep-mobile-panel__title-row">
              <h2 class="ep-mobile-panel__title">Menu</h2>
            </div>

            <div class="ep-mobile-panel__list-wrap">
              <ul class="ep-mobile-panel__list">
                {header.navItems.map((item, index) => (
                  <li class:list={['ep-mobile-panel__item', { 'is-first': index === 0 }]}>
                    <a
                      href={item.href}
                      class="ep-mobile-panel__link"
                      data-ep-menu-link
                      data-tina-field={tinaField(header, 'navItems', index)}
                    >
                      <span>{item.label.replace('\n', ' ')}</span>
                    </a>
                  </li>
                ))}

                <li class="ep-mobile-panel__item ep-mobile-panel__item--ctas">
                  <div class="ep-btn-shell ep-btn-shell--soft ep-mobile-cta-shell">
                    <div class="ep-soft-liquid">
                      <div class="ep-soft-liquid__frame">
                        <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                        <a
                          href={header.whatsAppHref}
                          class="ep-btn ep-btn--soft ep-soft-liquid__link ep-mobile-cta-btn"
                          target="_blank"
                          rel="noopener noreferrer"
                          data-ep-menu-link
                        >
                          <span>{header.primaryCtaLabel}</span>
                        </a>
                      </div>
                    </div>
                  </div>
                  <div class="ep-btn-shell ep-mobile-cta-shell">
                    <div class="ep-dark-liquid ep-dark-liquid--full">
                      <div class="ep-dark-liquid__frame">
                        <div class="ep-dark-liquid__overlay" aria-hidden="true"></div>
                        <a href={header.secondaryCtaHref} class="ep-btn ep-btn--dark ep-dark-liquid__link ep-mobile-cta-btn" data-ep-menu-link>
                          <span class="ep-btn-label">{header.secondaryCtaLabel}</span>
                        </a>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero" data-tina-field={tinaField(siteContent, 'hero')}>
        <img src={imageMap.hero} alt="English Plumber hero image" class="hero-bg" loading="eager" />
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <h1>
            <span>{hero.titleLine1}</span>
            <span class="script-line">{hero.titleLine2}</span>
          </h1>
          <p>{hero.description}</p>
          <div class="ep-soft-liquid">
            <div class="ep-soft-liquid__frame">
              <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
              <a href="#pricing" class="btn btn-soft ep-soft-liquid__link">{hero.primaryCtaLabel}</a>
            </div>
          </div>
        </div>
      </section>

      <span id="boiler-servicing" class="anchor-offset" aria-hidden="true"></span>
      <span id="radiator-services" class="anchor-offset" aria-hidden="true"></span>
      <span id="tap-repairs" class="anchor-offset" aria-hidden="true"></span>
      <span id="plumbing-handyman" class="anchor-offset" aria-hidden="true"></span>

      <section class="section section-services" data-tina-field={tinaField(siteContent, 'biomarkerPanel')}>
        <div class="container biomarker-section-shell">
          <div class="biomarker-layout">
            <div class="biomarker-copy">
              <div class="biomarker-copy-stack">
                <h2 class="biomarker-heading">
                  <span>{biomarkerPanel.titleLine1}</span><br />
                  <em>{biomarkerPanel.titleLine2}</em>
                </h2>
              </div>

              <div class="biomarker-cta biomarker-cta--desktop">
                <div class="ep-soft-liquid">
                  <div class="ep-soft-liquid__frame">
                    <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                    <a
                      href={header.secondaryCtaHref}
                      class="btn btn-soft ep-soft-liquid__link ep-soft-liquid__link--xl"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {biomarkerPanel.primaryCtaLabel}
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <div class="biomarker-pills-wrap">
              <div class="biomarker-pills-desktop">
                {biomarkerRows.map((row, rowIndex) => (
                  <div class="biomarker-pill-row">
                    {row.map((item, itemIndex) => (
                      <article class="biomarker-pill" data-tina-field={tinaField(biomarkerPanel, 'items', biomarkerRowStarts[rowIndex] + itemIndex)}>
                        <img src={resolveBiomarkerImage(item.imagePath)} alt={item.label} loading="lazy" width="40" height="40" decoding="async" />
                        <span>{item.label}</span>
                      </article>
                    ))}
                  </div>
                ))}
              </div>

              <div class="biomarker-pills-mobile">
                {biomarkerRows.map((row, rowIndex) => (
                  <div class="biomarker-marquee">
                    <div
                      class="biomarker-marquee-track"
                      data-biomarker-marquee
                      data-marquee-speed={String(biomarkerMobileSpeeds[rowIndex] ?? 36)}
                      data-marquee-offset={String(biomarkerMobileOffsets[rowIndex] ?? 0)}
                    >
                      {[...row, ...row].map((item, itemIndex) => (
                        <article
                          class="biomarker-pill biomarker-pill--mobile"
                          data-tina-field={tinaField(
                            biomarkerPanel,
                            'items',
                            biomarkerRowStarts[rowIndex] + (itemIndex % row.length),
                          )}
                        >
                          <img
                            src={resolveBiomarkerImage(item.imagePath)}
                            alt={item.label}
                            loading={itemIndex < row.length ? 'eager' : 'lazy'}
                            width="40"
                            height="40"
                            decoding="async"
                          />
                          <span>{item.label}</span>
                        </article>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="biomarker-cta biomarker-cta--mobile">
              <div class="ep-soft-liquid ep-soft-liquid--full">
                <div class="ep-soft-liquid__frame">
                  <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                  <a
                    href={header.secondaryCtaHref}
                    class="btn btn-soft ep-soft-liquid__link ep-soft-liquid__link--xl"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {biomarkerPanel.primaryCtaLabel}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-feature" data-tina-field={tinaField(siteContent, 'featurePanel')}>
        <div class="container">
          <div class="feature-cards-grid">
            <article class="image-card">
              <img src={imageMap.card1} alt={serviceCards[0].alt} width="620" height="420" loading="lazy" />
              <div class="card-caption">
                <h3>
                  <span>{serviceCards[0].titleLine1}</span>
                  <span class="script-line small">{serviceCards[0].titleLine2}</span>
                </h3>
                <div class="ep-soft-liquid">
                  <div class="ep-soft-liquid__frame">
                    <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                    <a href={serviceCards[0].href} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                      {featurePanel.cardCtaLabel}
                    </a>
                  </div>
                </div>
              </div>
            </article>

            <article class="feature-text-card">
              <h3>
                <span>{featurePanel.headingLine1}</span>
                <span class="script-line small">{featurePanel.headingLine2}</span>
              </h3>
              <p>{featurePanel.description}</p>
              <div class="stats">
                <div>
                  <strong>{featurePanel.stat1.value}</strong>
                  <span>{featurePanel.stat1.line1}</span>
                  <span>{featurePanel.stat1.line2}</span>
                </div>
                <div>
                  <strong>{featurePanel.stat2.value}</strong>
                  <span>{featurePanel.stat2.line1}</span>
                  <span>{featurePanel.stat2.line2}</span>
                </div>
              </div>
            </article>

            <article class="image-card">
              <img src={imageMap.card2} alt={serviceCards[1].alt} width="620" height="420" loading="lazy" />
              <div class="card-caption">
                <h3>
                  <span>{serviceCards[1].titleLine1}</span>
                  <span class="script-line small">{serviceCards[1].titleLine2}</span>
                </h3>
                <div class="ep-soft-liquid">
                  <div class="ep-soft-liquid__frame">
                    <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                    <a href={serviceCards[1].href} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                      {featurePanel.cardCtaLabel}
                    </a>
                  </div>
                </div>
              </div>
            </article>

            <article class="image-card">
              <img src={imageMap.card3} alt={serviceCards[2].alt} width="620" height="420" loading="lazy" />
              <div class="card-caption">
                <h3>
                  <span>{serviceCards[2].titleLine1}</span>
                  <span class="script-line small">{serviceCards[2].titleLine2}</span>
                </h3>
                <div class="ep-soft-liquid">
                  <div class="ep-soft-liquid__frame">
                    <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                    <a href={serviceCards[2].href} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                      {featurePanel.prescriptionCard.ctaLabel}
                    </a>
                  </div>
                </div>
              </div>
            </article>

            <article class="feature-text-card">
              <h3>
                <span>{featurePanel.careHeadingLine1}</span>
                <span class="script-line small">{featurePanel.careHeadingLine2}</span>
              </h3>
              <p>{featurePanel.careDescription}</p>
              <div class="cert-pill" id="certifications">
                <strong>{featurePanel.badgeTitle}</strong>
                <span>{featurePanel.badgeStatus}</span>
              </div>
              <span id="language" class="anchor-offset" aria-hidden="true"></span>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-trust" data-tina-field={tinaField(siteContent, 'trustSection')}>
        <div class="container">
          <h2>
            <span>{trustSection.headingLine1}</span>
            <span class="script-line">{trustSection.headingLine2}</span>
          </h2>

          <div class="trust-grid">
            {trustSection.videoCards.map((item, index) => (
              <article class="trust-card media-card">
                <img src={avatarMap[index % avatarMap.length]} alt={item.thumbnailAlt} class="trust-visual" width="460" height="280" loading="lazy" />
                <div class="trust-meta">
                  <span class="handle">{item.handle}</span>
                  <span class="member-pill">{trustSection.memberLabel}</span>
                  <span class="meta-copy">{item.meta}</span>
                </div>
              </article>
            ))}

            {trustSection.textCards.map((item, index) => (
              <article class="trust-card quote-card">
                <div class="quote-head">
                  <img src={avatarMap[index % avatarMap.length]} alt={item.profileAlt} width="48" height="48" loading="lazy" />
                  <div>
                    <strong>{item.name}</strong>
                    <span>{trustSection.memberLabel}</span>
                  </div>
                </div>
                <p>{item.quote}</p>
              </article>
            ))}
          </div>

          <div class="trust-footer-link">
            <a href={header.whatsAppHref} target="_blank" rel="noopener noreferrer">{trustSection.readMoreLabel}</a>
          </div>
        </div>
      </section>

      <section class="section section-command" data-tina-field={tinaField(siteContent, 'commandCenterSection')}>
        <div class="container command-layout">
          <div>
            <h2>
              <span>{commandCenterSection.headingLine1}</span>
              <span class="script-line">{commandCenterSection.headingLine2}</span>
            </h2>
            <p>{commandCenterSection.description}</p>
            <div class="ep-soft-liquid">
              <div class="ep-soft-liquid__frame">
                <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                <a href="#pricing" class="btn btn-soft ep-soft-liquid__link">{commandCenterSection.ctaLabel}</a>
              </div>
            </div>
          </div>
          <div class="command-image-wrap">
            <img src={imageMap.command} alt={commandCenterSection.appImageAlt} width="660" height="760" loading="lazy" />
            <p class="loading-copy">{commandCenterSection.loadingAnimationLabel}</p>
          </div>
        </div>
      </section>

      <section class="section section-process" id="service-area" data-tina-field={tinaField(siteContent, 'ourProcessSection')}>
        <div class="container process-layout">
          <img src={imageMap.process} alt={ourProcessSection.imageAlt} width="580" height="600" loading="lazy" />
          <div>
            <h2>
              <span>{ourProcessSection.headingLine1}</span>
              <span class="script-line">{ourProcessSection.headingLine2}</span>
            </h2>
            <ol class="step-list">
              {ourProcessSection.steps.map((step) => (
                <li>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <section class="section section-pricing" id="pricing" data-tina-field={tinaField(siteContent, 'choosePathSection')}>
        <div class="container">
          <h2>{choosePathSection.title}</h2>
          <p class="section-subtitle">{choosePathSection.subtitle}</p>

          <div class="plan-grid">
            {choosePathSection.plans.map((plan) => (
              <article class={`plan-card ${plan.isPopular ? 'popular' : ''}`}>
                <div class="plan-top">
                  <p class="plan-name">{plan.name}</p>
                  <h3>{plan.nameStyle}</h3>
                  <p class="tagline">{plan.tagline}</p>
                  <div class="price-row">
                    <strong>{plan.pricing.oneTimePrice}</strong>
                    <span>{plan.pricing.discountPercentage}</span>
                  </div>
                  <p class="price-note">{plan.pricing.twiceAnnuallyBillingText}</p>
                  <p class="price-note">{plan.pricing.annuallyBillingText}</p>
                </div>

                <div class="plan-body">
                  {plan.feature.map((group) => (
                    <section>
                      <h4>{group.categoryName}</h4>
                      <ul>
                        {group.features.map((feature) => (
                          <li>{feature.name}</li>
                        ))}
                      </ul>
                    </section>
                  ))}

                  {plan.restriction.map((group) => (
                    <section class="restriction">
                      <h4>{group.categoryName}</h4>
                      <ul>
                        {group.features.map((feature) => (
                          <li>{feature.name}</li>
                        ))}
                      </ul>
                    </section>
                  ))}
                </div>

                <div class="ep-dark-liquid ep-dark-liquid--full">
                  <div class="ep-dark-liquid__frame">
                    <div class="ep-dark-liquid__overlay" aria-hidden="true"></div>
                    <a href={header.whatsAppHref} class="btn btn-dark ep-dark-liquid__link" target="_blank" rel="noopener noreferrer">
                      <span class="ep-btn-label">{plan.link.label}</span>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-faq" data-tina-field={tinaField(siteContent, 'faqSection')}>
        <div class="container faq-layout">
          <div>
            <h2>
              <span>{faqSection.headingLine1}</span>
              <span class="script-line">{faqSection.headingLine2}</span>
            </h2>

            <div class="faq-list">
              {faqSection.items.map((item) => (
                <details>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>

            <div class="faq-support">
              <h3>{faqSection.supportTitle}</h3>
              <p>{faqSection.supportDescription}</p>
              <div class="ep-soft-liquid">
                <div class="ep-soft-liquid__frame">
                  <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                  <a href={faqSection.supportCtaHref} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                    {faqSection.supportCtaLabel}
                  </a>
                </div>
              </div>
            </div>
          </div>
          <img src={imageMap.faq} alt={faqSection.cardImageAlt} width="520" height="540" loading="lazy" />
        </div>
      </section>

      <section class="section section-mission" data-tina-field={tinaField(siteContent, 'missionSection')}>
        <div class="container mission-layout">
          <article class="mission-card">
            <img src={imageMap.mission} alt={missionSection.mission.imageAlt} width="520" height="620" loading="lazy" />
            <div class="mission-copy">
              <p class="eyebrow">{missionSection.mission.name}</p>
              <p class="role">{missionSection.mission.role}</p>
              <h2>
                <span>{missionSection.mission.headingLine1}</span>
                <span class="script-line">{missionSection.mission.headingLine2}</span>
              </h2>
              <p>{missionSection.mission.description}</p>
              <div class="ep-soft-liquid">
                <div class="ep-soft-liquid__frame">
                  <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                  <a href={missionSection.mission.ctaHref} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                    {missionSection.mission.ctaLabel}
                  </a>
                </div>
              </div>
            </div>
          </article>

          <article class="gallery-card">
            <div class="gallery-head">
              <h2>
                <span>{missionSection.gallery.headingLine1}</span>
                <span class="script-line">{missionSection.gallery.headingLine2}</span>
              </h2>
              <div class="ep-soft-liquid">
                <div class="ep-soft-liquid__frame">
                  <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                  <a href={missionSection.gallery.ctaHref} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                    {missionSection.gallery.ctaLabel}
                  </a>
                </div>
              </div>
            </div>
            <div class="gallery-grid">
              <img src={imageMap.gallery1} alt={missionSection.gallery.images[0].alt} width="620" height="420" loading="lazy" />
              <img src={imageMap.gallery2} alt={missionSection.gallery.images[1].alt} width="620" height="420" loading="lazy" />
            </div>
          </article>
        </div>
      </section>

      <section class="section section-newsletter" data-tina-field={tinaField(siteContent, 'newsletterSection')}>
        <img src={imageMap.newsletter} alt={newsletterSection.backgroundImageAlt} class="newsletter-bg" loading="lazy" />
        <div class="newsletter-overlay"></div>
        <div class="container newsletter-content">
          <h2>
            <span>{newsletterSection.headingLine1}</span>
            <span class="script-line">{newsletterSection.headingLine2}</span>
          </h2>
          <p>{newsletterSection.description}</p>
          <div class="ep-soft-liquid">
            <div class="ep-soft-liquid__frame">
              <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
              <a href={newsletterSection.ctaHref} class="btn btn-soft ep-soft-liquid__link" target="_blank" rel="noopener noreferrer">
                {newsletterSection.ctaLabel}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer" data-tina-field={tinaField(siteContent, 'footerSection')}>
      <div class="container footer-shell">
        <div class="footer-main">
          <section class="footer-left">
            <img src="/images/logo-big.svg" alt={footerSection.logoAlt} class="footer-logo" width="900" height="220" loading="lazy" />

            <p class="subscription-text">{footerSection.subscriptionText}</p>
            <form class="newsletter-form" action="#" method="post">
              <input type="email" placeholder={footerSection.emailPlaceholder} aria-label={footerSection.emailPlaceholder} />
              <div class="ep-soft-liquid">
                <div class="ep-soft-liquid__frame">
                  <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                  <button type="submit" class="btn btn-soft ep-soft-liquid__link">{footerSection.subscribeLabel}</button>
                </div>
              </div>
            </form>

            <div class="footer-socials">
              <p>{footerSection.followUsLabel}</p>
              <div>
                {externalSocials.map((item) => (
                  <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
                ))}
              </div>
            </div>

            <div class="footer-links">
              <section>
                <h3>{footerSection.supportTitle}</h3>
                <ul>
                  {footerSection.supportLinks.map((link) => (
                    <li><a href={link.href}>{link.label}</a></li>
                  ))}
                </ul>
              </section>
              <section>
                <h3>{footerSection.aboutTitle}</h3>
                <ul>
                  {footerSection.aboutLinks.map((link) => (
                    <li><a href={link.href}>{link.label}</a></li>
                  ))}
                </ul>
              </section>
            </div>

            <p class="disclaimer">{footerSection.legalDisclaimer}</p>
          </section>

          <section class="footer-card-col">
            <img src={imageMap.footer} alt={footerSection.cardImageAlt} class="footer-card-image" width="382" height="467" loading="lazy" />
            <p>{footerSection.appPrompt}</p>
            <div class="store-links">
              <a href={footerSection.appStoreHref} target="_blank" rel="noopener noreferrer">{footerSection.appStoreAlt}</a>
              <a href={footerSection.googlePlayHref} target="_blank" rel="noopener noreferrer">{footerSection.googlePlayAlt}</a>
            </div>
          </section>
        </div>

        <div class="footer-bottom">
          <p>{footerSection.copyrightText}</p>
          <div class="footer-bottom-socials">
            {externalSocials.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
    </footer>
    <script>
      import { initHeaderBehavior } from '../scripts/header';

      initHeaderBehavior();
    </script>
</BaseLayout>
