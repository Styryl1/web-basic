---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TinaInlineBridge from '../react/TinaInlineBridge.tsx';
import { transformImageForRequest, transformImageSrcSetForRequest } from '../../data/cloudflareImage';
import { getHomeTranslation, getLocaleSettings, loadSiteDocument } from '../../data/siteContent';
import {
  DEFAULT_LOCALE,
  getLanguageSwitcherHref,
  getLocalizedPath,
  isLocale,
  type Locale,
} from '../../i18n/config';
import { tinaField } from 'tinacms/dist/react';
import '../../styles/index.css';

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const optimizedImageMap = new Map<string, string>([
  ['family photo.png', '/optimized/family-photo-hero.webp'],
  ['boiler emoji.png', '/optimized/boiler-emoji.webp'],
  ['radiator emoji.png', '/optimized/radiator-emoji.webp'],
  ['pipe repair emoji.png', '/optimized/pipe-repair-emoji.webp'],
  ['tap emoji.png', '/optimized/tap-emoji.webp'],
  ['tap repair emoji.png', '/optimized/tap-repair-emoji.webp'],
  ['pipe emoji.png', '/optimized/pipe-emoji.webp'],
  ['plumbing emoji.png', '/optimized/plumbing-emoji.webp'],
  ['friendly emoji.png', '/optimized/friendly-emoji.webp'],
  ['gas saving emojio.png', '/optimized/gas-saving-emoji.webp'],
  ['dutch english emoji.png', '/optimized/dutch-english-emoji.webp'],
  ['boiler servicing avatar.png', '/optimized/boiler-servicing-avatar.webp'],
  ['radiator services avatar.png', '/optimized/radiator-services-avatar.webp'],
  ['tap repairs avatar.png', '/optimized/tap-repairs-avatar.webp'],
  ['english plumber logo final.png', '/optimized/english-plumber-logo-final.webp'],
  ['english plumber logo light.png', '/optimized/english-plumber-logo-light.webp'],
  ['logo-wordmark-transparent.png', '/optimized/logo-wordmark-transparent.webp'],
  ['logo-wordmark-card.png', '/optimized/logo-wordmark-card.webp'],
  ['boiler install.jpg', '/optimized/boiler-install-review.webp'],
  ['boiler service.jpg', '/optimized/boiler-service-review.webp'],
  ['tap and sink install.jpg', '/optimized/tap-and-sink-install-review.webp'],
  ['pipe repair.jpg', '/optimized/pipe-repair-review.webp'],
  ['werkspot logo.png', '/optimized/werkspot-logo.webp'],
  ['whatsapp conversation.png', '/optimized/whatsapp-conversation.webp'],
]);

const responsiveImageMap = new Map<string, Array<{ src: string; width: number }>>([
  [
    'family photo.png',
    [
      { src: '/optimized/family-photo-hero-mobile.webp', width: 900 },
      { src: '/optimized/family-photo-hero.webp', width: 1179 },
    ],
  ],
]);

const imageDimensionMap = new Map<string, { width: number; height: number }>([
  ['family-photo-hero.webp', { width: 1179, height: 788 }],
  ['family-photo-hero-mobile.webp', { width: 900, height: 602 }],
  ['english-plumber-logo-final.webp', { width: 840, height: 200 }],
  ['english-plumber-logo-light.webp', { width: 1260, height: 300 }],
  ['logo-wordmark-transparent.webp', { width: 840, height: 165 }],
  ['logo-wordmark-card.webp', { width: 1260, height: 355 }],
  ['whatsapp-conversation.webp', { width: 768, height: 1152 }],
  ['werkspot-logo.webp', { width: 96, height: 96 }],
]);

const getAssetBasename = (value: string | undefined): string | null => {
  if (!value) return null;

  try {
    const url = /^https?:\/\//i.test(value) ? new URL(value) : new URL(value, 'https://englishplumber.nl');
    const basename = decodeURIComponent(url.pathname.split('/').pop() ?? '').trim().toLowerCase();
    return basename || null;
  } catch {
    return value.trim().toLowerCase();
  }
};

const isSameOriginAdminRequest = (request: Request, url: URL): boolean => {
  const referer = request.headers.get('referer');
  if (!referer) return false;

  try {
    const refererUrl = new URL(referer);
    return refererUrl.origin === url.origin && refererUrl.pathname.startsWith('/admin');
  } catch {
    return false;
  }
};

const { locale = DEFAULT_LOCALE, currentPath = '/' } = Astro.props as Props;
const tinaPreviewEnabled = isSameOriginAdminRequest(Astro.request, Astro.url);
const { siteContent, tinaBridgeProps } = await loadSiteDocument({ enableTinaPreview: tinaPreviewEnabled });
const siteSettings = siteContent.siteSettings as any;
const pageContent = getHomeTranslation(siteContent, locale) as any;
const localeSettings = getLocaleSettings(siteContent, locale) as any;

const {
  mediaOrigin,
  baseCity,
  whatsappNumber,
  canonicalOrigin,
  ogImage,
  businessName,
  homepageUrl,
} = siteSettings;

const {
  heroImagePath,
  seoTitle,
  seoDescription,
  header,
  hero,
  biomarkerPanel,
  featurePanel,
  trustSection,
  ourProcessSection,
  choosePathSection,
  faqSection,
  missionSection,
  newsletterSection,
  serviceAreaSection,
  footerSection,
} = pageContent;

const serviceCards = [
  ...featurePanel.cards,
  {
    alt: featurePanel.prescriptionCard.alt,
    titleLine1: featurePanel.prescriptionCard.titleLine1,
    titleLine2: featurePanel.prescriptionCard.titleLine2,
    href: featurePanel.prescriptionCard.href,
    imagePath: featurePanel.prescriptionCard.imagePath,
  },
];

const imageMap = {
  hero: '/images/hero.svg',
  card1: '/images/service-card-1.svg',
  card2: '/images/service-card-2.svg',
  card3: '/images/service-card-3.svg',
  process: '/images/process.svg',
  faq: '/images/faq-card.svg',
  mission: '/images/mission.svg',
  gallery1: '/images/gallery-1.svg',
  gallery2: '/images/gallery-2.svg',
  newsletter: '/images/newsletter-bg.svg',
  footer: '/images/footer-card.svg',
};
const trustThumbnailFallbacks = [imageMap.gallery1, imageMap.gallery2, imageMap.gallery1, imageMap.gallery2];
const trustAvatarFallbacks = ['/images/avatar-1.svg', '/images/avatar-2.svg', '/images/avatar-3.svg', '/images/avatar-4.svg'];
const localeOptions = (siteSettings.locales ?? []).filter((entry: any) => isLocale(entry?.code));
const siteOrigin = canonicalOrigin || homepageUrl || 'https://englishplumber.nl/';
const siteHost = new URL(siteOrigin).host;
const mediaHost = (() => {
  if (!mediaOrigin) return undefined;

  try {
    return new URL(mediaOrigin).host;
  } catch {
    return undefined;
  }
})();
const imageTransformHosts = [siteHost, mediaHost].filter((value, index, values): value is string => Boolean(value) && values.indexOf(value) === index);
const alternateLinks = [
  ...localeOptions.map((entry: any) => ({
    hrefLang: entry.htmlLang ?? entry.code,
    href: getLocalizedPath(currentPath, entry.code),
  })),
  {
    hrefLang: 'x-default',
    href: getLocalizedPath(currentPath, DEFAULT_LOCALE),
  },
];
const alternateOgLocales = localeOptions
  .filter((entry: any) => entry.code !== locale)
  .map((entry: any) => entry.ogLocale)
  .filter(Boolean);
const languageSwitcherOptions = localeOptions.map((entry: any) => ({
  ...entry,
  href: getLanguageSwitcherHref(currentPath, entry.code),
  isCurrent: entry.code === locale,
}));

const trustReviews = (trustSection.videoCards ?? [])
  .slice(0, 4)
  .map((videoCard, index) => ({
    videoCard,
    textCard: trustSection.textCards?.[index],
    index,
  }))
  .filter((entry) => Boolean(entry.videoCard && entry.textCard));

const biomarkerItems = (biomarkerPanel.items ?? []).filter((item) => Boolean(item));
const biomarkerRows = [biomarkerItems.slice(0, 3), biomarkerItems.slice(3, 7), biomarkerItems.slice(7, 10)];
const biomarkerRowStarts = [0, 3, 7];
const biomarkerMobileSpeeds = [34, 41, 37];
const biomarkerMobileOffsets = [102.083, 728.5, 652.667];

const resolveLocalizedHref = (value: string | undefined): string => {
  if (!value) return '#';
  if (value.startsWith('#')) return value;
  if (/^(mailto:|tel:)/i.test(value)) return value;

  if (/^https?:\/\//i.test(value)) {
    try {
      const url = new URL(value);
      if (url.host !== siteHost) return value;
      return `${getLocalizedPath(url.pathname, locale)}${url.search}${url.hash}`;
    } catch {
      return value;
    }
  }

  try {
    const url = new URL(value, 'https://englishplumber.nl');
    if (value.startsWith('/')) {
      return `${getLocalizedPath(url.pathname, locale)}${url.search}${url.hash}`;
    }
  } catch {
    // Fall through to return the original value.
  }

  return value;
};

const isExternalHref = (value: string | undefined): boolean => /^(https?:\/\/|mailto:|tel:)/i.test(value ?? '');

const resolveContentImage = (imagePath: string | undefined, fallbackPath: string) => {
  if (!imagePath) return fallbackPath;
  const optimizedImage = optimizedImageMap.get(getAssetBasename(imagePath) ?? '');
  if (optimizedImage) return optimizedImage;
  if (/^https?:\/\//i.test(imagePath)) return imagePath;
  if (imagePath.startsWith('/api/media/file/')) {
    try {
      return new URL(imagePath, mediaOrigin).toString();
    } catch {
      return imagePath;
    }
  }
  return imagePath;
};

const getResponsiveImageSrcSet = (imagePath: string | undefined): string | undefined => {
  const variants = responsiveImageMap.get(getAssetBasename(imagePath) ?? '');
  if (!variants?.length) return undefined;

  return variants.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
};

const getImageDimensions = (imagePath: string | undefined, fallback: { width: number; height: number }) =>
  imageDimensionMap.get(getAssetBasename(imagePath) ?? '') ?? fallback;

const optimizeImage = (
  imagePath: string,
  options: { width?: number; height?: number; quality?: number; fit?: 'contain' | 'cover' | 'crop' | 'pad' | 'scale-down' },
) => transformImageForRequest(imagePath, Astro.url, options, imageTransformHosts);

const optimizeImageSrcSet = (
  imagePath: string,
  variants: Array<{ width?: number; height?: number; quality?: number; fit?: 'contain' | 'cover' | 'crop' | 'pad' | 'scale-down' }>,
) => transformImageSrcSetForRequest(imagePath, Astro.url, variants, imageTransformHosts);

const resolveBiomarkerImage = (imagePath: string | undefined) =>
  optimizeImage(resolveContentImage(imagePath, '/images/hero.svg'), { width: 96, quality: 72, fit: 'scale-down' });
const heroBackgroundImageSource = resolveContentImage(heroImagePath, imageMap.hero);
const heroBackgroundImage = optimizeImage(heroBackgroundImageSource, { width: 1179, quality: 72, fit: 'cover' });
const heroBackgroundImageSrcSet =
  optimizeImageSrcSet(heroBackgroundImageSource, [
    { width: 900, quality: 68, fit: 'cover' },
    { width: 1179, quality: 72, fit: 'cover' },
  ]) ?? getResponsiveImageSrcSet(heroImagePath);
const heroBackgroundImageDimensions = getImageDimensions(heroBackgroundImageSource, { width: 1179, height: 788 });
const headerLogoSource = resolveContentImage(header.logoImagePath, '/images/logo-wordmark-transparent.png');
const headerLogoImage = optimizeImage(headerLogoSource, { width: 640, quality: 80, fit: 'scale-down' });
const headerLogoDimensions = getImageDimensions(headerLogoSource, { width: 840, height: 200 });
const featureCardFallbacks = [imageMap.card1, imageMap.card2, imageMap.card3];
const featureCardImages = serviceCards.map((card, index) =>
  optimizeImage(resolveContentImage(card.imagePath, featureCardFallbacks[index] ?? imageMap.card1), { width: 1240, quality: 74, fit: 'cover' }),
);
const processImage = optimizeImage(resolveContentImage(ourProcessSection.imagePath, imageMap.process), { width: 960, quality: 74, fit: 'cover' });
const faqImage = optimizeImage(resolveContentImage(faqSection.cardImagePath, imageMap.faq), { width: 780, quality: 74, fit: 'cover' });
const missionImage = optimizeImage(resolveContentImage(missionSection.mission.imagePath, imageMap.mission), { width: 960, quality: 74, fit: 'cover' });
const newsletterImage = optimizeImage(resolveContentImage(newsletterSection.backgroundImagePath, imageMap.newsletter), {
  width: 1440,
  quality: 72,
  fit: 'cover',
});
const footerLogoSource = resolveContentImage(footerSection.logoImagePath, '/images/logo-wordmark-card.png');
const footerLogoImage = optimizeImage(footerLogoSource, { width: 1260, quality: 80, fit: 'scale-down' });
const footerLogoDimensions = getImageDimensions(footerLogoSource, { width: 1260, height: 300 });
const footerDesktopCardSource = resolveContentImage(footerSection.cardDesktopImagePath, imageMap.footer);
const footerDesktopCardImage = optimizeImage(footerDesktopCardSource, { width: 768, quality: 76, fit: 'cover' });
const footerDesktopCardDimensions = getImageDimensions(footerDesktopCardSource, { width: 382, height: 467 });
const footerMobileCardImage = optimizeImage(resolveContentImage(footerSection.cardMobileImagePath, footerDesktopCardSource), {
  width: 640,
  quality: 76,
  fit: 'cover',
});
const serviceAreaMapEmbedUrl = serviceAreaSection.mapEmbedUrl || 'https://www.google.com/maps?q=Medemblik,+Netherlands&output=embed';
const homeAnchorHref = '#top';

const resolveAbsoluteUrl = (value?: string) => {
  if (!value) return undefined;
  try {
    return new URL(value).toString();
  } catch {
    // Resolve relative paths against canonical/home URL.
  }

  const base = canonicalOrigin || homepageUrl || 'https://englishplumber.nl/';

  try {
    return new URL(value, base).toString();
  } catch {
    return undefined;
  }
};

const canonicalUrl = resolveAbsoluteUrl(getLocalizedPath(currentPath, locale)) || resolveAbsoluteUrl(canonicalOrigin || homepageUrl) || 'https://englishplumber.nl/';
const canonicalUrlForSchema = canonicalUrl;
const businessImageUrlForSchema = resolveAbsoluteUrl(ogImage || heroImagePath);
const businessLogoUrlForSchema = resolveAbsoluteUrl(header.logoImagePath);
const businessMapUrlForSchema = resolveAbsoluteUrl(serviceAreaSection.mapEmbedUrl);
const businessPhoneForSchema = typeof whatsappNumber === 'string' ? whatsappNumber.replace(/\s+/g, ' ').trim() : '';
const businessAreaServedForSchema = Array.isArray(serviceAreaSection.areas)
  ? serviceAreaSection.areas
      .filter((area) => typeof area === 'string' && area.trim().length > 0)
      .map((area) => ({ '@type': 'City', name: area.trim() }))
  : [];

const localBusinessStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  '@id': `${canonicalUrlForSchema}#localbusiness`,
  name: businessName,
  url: canonicalUrlForSchema,
  ...(businessPhoneForSchema ? { telephone: businessPhoneForSchema } : {}),
  ...(businessImageUrlForSchema ? { image: businessImageUrlForSchema } : {}),
  ...(businessLogoUrlForSchema ? { logo: businessLogoUrlForSchema } : {}),
  ...(businessMapUrlForSchema ? { hasMap: businessMapUrlForSchema } : {}),
  address: {
    '@type': 'PostalAddress',
    addressLocality: baseCity,
    addressRegion: serviceAreaSection.regionName ?? baseCity,
    addressCountry: 'NL',
  },
  areaServed: [{ '@type': 'AdministrativeArea', name: serviceAreaSection.regionName ?? baseCity }, ...businessAreaServedForSchema],
  sameAs: [homepageUrl, header?.whatsAppHref].filter(Boolean),
  description: seoDescription,
  inLanguage: localeSettings.htmlLang,
  availableLanguage: localeOptions.map((entry: any) => entry.nativeLabel ?? entry.label ?? entry.code),
};

const faqMainEntitiesForSchema = Array.isArray(faqSection.items)
  ? faqSection.items
      .filter((item) => item && typeof item.question === 'string' && typeof item.answer === 'string')
      .map((item) => ({
        '@type': 'Question',
        name: item.question.trim(),
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer.trim(),
        },
      }))
      .filter((entity) => entity.name.length > 0 && entity.acceptedAnswer.text.length > 0)
  : [];

const faqPageStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: localeSettings.htmlLang,
  mainEntity: faqMainEntitiesForSchema,
};

const localBusinessStructuredDataJson = JSON.stringify(localBusinessStructuredData);
const faqPageStructuredDataJson = faqMainEntitiesForSchema.length > 0 ? JSON.stringify(faqPageStructuredData) : null;

const getTrustThumbnailImage = (videoCard: Record<string, unknown>, index: number) =>
  optimizeImage(resolveContentImage(videoCard.thumbnailImagePath as string | undefined, trustThumbnailFallbacks[index % trustThumbnailFallbacks.length]), {
    width: 920,
    quality: 74,
    fit: 'cover',
  });

const getTrustAvatarImage = (videoCard: Record<string, unknown>, textCard: Record<string, unknown>, index: number) =>
  optimizeImage(
    resolveContentImage(
      (textCard.profileImagePath as string | undefined) ?? (videoCard.profileImagePath as string | undefined),
      trustAvatarFallbacks[index % trustAvatarFallbacks.length],
    ),
    { width: 96, quality: 82, fit: 'cover' },
  );
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical={canonicalUrl}
  ogImage={ogImage}
  siteName={businessName}
  lang={localeSettings.htmlLang}
  ogLocale={localeSettings.ogLocale}
  alternateLocales={alternateOgLocales}
  alternates={alternateLinks}
>
    <Fragment slot="head">
      <script is:inline type="application/ld+json" set:html={localBusinessStructuredDataJson}></script>
      {faqPageStructuredDataJson && <script is:inline type="application/ld+json" set:html={faqPageStructuredDataJson}></script>}
      <link
        rel="preload"
        as="image"
        href={heroBackgroundImage}
        {...(heroBackgroundImageSrcSet ? { imagesrcset: heroBackgroundImageSrcSet, imagesizes: '100vw' } : {})}
      />
    </Fragment>
    {
      tinaBridgeProps && (
        <>
          {/* @ts-expect-error custom Astro client directive */}
          <TinaInlineBridge {...tinaBridgeProps} client:tina />
        </>
      )
    }

    <header
      class="ep-header"
      data-ep-header
      data-ep-menu-open-label={header.openMenuAriaLabel}
      data-ep-menu-close-label={header.closeMenuAriaLabel}
      data-tina-field={tinaField(pageContent, 'header')}
    >
      <div class="container ep-header__container">
        <div class="ep-header__shell">
          <div class="ep-header__ring ep-header__ring--outer" aria-hidden="true"></div>
          <div class="ep-header__ring ep-header__ring--inner" aria-hidden="true"></div>

          <div class="ep-header__inner">
            <a href={homeAnchorHref} class="ep-header__logo-link" aria-label={header.homeAriaLabel}>
              <img
                src={headerLogoImage}
                alt={header.logoAlt}
                width={headerLogoDimensions.width}
                height={headerLogoDimensions.height}
                class="ep-header__logo"
                decoding="async"
                fetchpriority="low"
                data-tina-field={tinaField(header, 'logoImagePath')}
              />
            </a>

            <nav class="ep-header__nav" aria-label={header.mainNavAriaLabel}>
              <ul class="ep-header__nav-list">
                {header.navItems.map((item, index) => (
                  <li>
                    <a href={resolveLocalizedHref(item.href)} class="ep-header__nav-link" data-tina-field={tinaField(header, 'navItems', index)}>
                      <span>{item.label}</span>
                    </a>
                  </li>
                ))}
              </ul>

              <div class="ep-header__cta-group">
                <div class="ep-language-switcher" aria-label={header.languageSwitcherAriaLabel}>
                  {languageSwitcherOptions.map((option, index) =>
                    option.isCurrent ? (
                      <span
                        class="ep-language-switcher__option is-current"
                        aria-current="page"
                        aria-label={option.nativeLabel}
                        title={option.nativeLabel}
                        data-tina-field={tinaField(siteSettings, 'locales', index)}
                      >
                        {option.shortLabel}
                      </span>
                    ) : (
                      <a
                        href={option.href}
                        class="ep-language-switcher__option"
                        aria-label={option.nativeLabel}
                        title={option.nativeLabel}
                        data-tina-field={tinaField(siteSettings, 'locales', index)}
                      >
                        {option.shortLabel}
                      </a>
                    ),
                  )}
                </div>
                <div class="ep-btn-shell ep-btn-shell--soft">
                  <div class="ep-soft-liquid">
                    <div class="ep-soft-liquid__frame">
                      <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                      <a
                        href={resolveLocalizedHref(header.whatsAppHref)}
                        class="ep-btn ep-btn--soft ep-soft-liquid__link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span>{header.primaryCtaLabel}</span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </nav>

            <button
              class="ep-header__menu-btn"
              type="button"
              aria-label={header.openMenuAriaLabel}
              aria-expanded="false"
              aria-controls="mobile-nav"
              data-ep-menu-btn
            >
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </button>
          </div>
        </div>

        <div class="ep-mobile-panel" id="mobile-nav" role="dialog" aria-modal="true" aria-label={header.mobileNavAriaLabel} hidden>
          <div class="ep-mobile-panel__head">
            <a href={homeAnchorHref} class="ep-mobile-panel__logo-link" aria-label={header.homeAriaLabel}>
              <img
                src={headerLogoImage}
                alt={header.logoAlt}
                width={headerLogoDimensions.width}
                height={headerLogoDimensions.height}
                class="ep-mobile-panel__logo"
                loading="lazy"
                decoding="async"
                data-tina-field={tinaField(header, 'logoImagePath')}
              />
            </a>

            <button
              class="ep-mobile-panel__close-btn"
              type="button"
              aria-label={header.closeMenuAriaLabel}
              aria-expanded="true"
              aria-controls="mobile-nav"
              data-ep-menu-close
            >
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </button>
          </div>

          <div class="ep-mobile-panel__body">
            <div class="ep-mobile-panel__title-row">
              <h2 class="ep-mobile-panel__title">{header.mobileMenuTitle}</h2>
              <div class="ep-language-switcher ep-language-switcher--mobile" aria-label={header.languageSwitcherAriaLabel}>
                {languageSwitcherOptions.map((option, index) =>
                  option.isCurrent ? (
                    <span
                      class="ep-language-switcher__option is-current"
                      aria-current="page"
                      aria-label={option.nativeLabel}
                      title={option.nativeLabel}
                      data-tina-field={tinaField(siteSettings, 'locales', index)}
                    >
                      {option.shortLabel}
                    </span>
                  ) : (
                    <a
                      href={option.href}
                      class="ep-language-switcher__option"
                      aria-label={option.nativeLabel}
                      title={option.nativeLabel}
                      data-tina-field={tinaField(siteSettings, 'locales', index)}
                    >
                      {option.shortLabel}
                    </a>
                  ),
                )}
              </div>
            </div>

            <div class="ep-mobile-panel__list-wrap">
              <ul class="ep-mobile-panel__list">
                {header.navItems.map((item, index) => (
                  <li class:list={['ep-mobile-panel__item', { 'is-first': index === 0 }]}>
                    <a
                      href={resolveLocalizedHref(item.href)}
                      class="ep-mobile-panel__link"
                      data-ep-menu-link
                      data-tina-field={tinaField(header, 'navItems', index)}
                    >
                      <span>{item.label.replace('\n', ' ')}</span>
                    </a>
                  </li>
                ))}

                <li class="ep-mobile-panel__item ep-mobile-panel__item--ctas">
                  <div class="ep-btn-shell ep-btn-shell--soft ep-mobile-cta-shell">
                    <div class="ep-soft-liquid">
                      <div class="ep-soft-liquid__frame">
                        <div class="ep-soft-liquid__overlay" aria-hidden="true"></div>
                        <a
                          href={resolveLocalizedHref(header.whatsAppHref)}
                          class="ep-btn ep-btn--soft ep-soft-liquid__link ep-mobile-cta-btn"
                          target="_blank"
                          rel="noopener noreferrer"
                          data-ep-menu-link
                        >
                          <span>{header.primaryCtaLabel}</span>
                        </a>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero" data-tina-field={tinaField(pageContent, 'hero')}>
        <img
          src={heroBackgroundImage}
          srcset={heroBackgroundImageSrcSet}
          sizes={heroBackgroundImageSrcSet ? '100vw' : undefined}
          alt={hero.imageAlt}
          class="hero-bg"
          loading="eager"
          fetchpriority="high"
          decoding="async"
